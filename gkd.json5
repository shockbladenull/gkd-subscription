// 自用 GKD 订阅
// 已包含小米智能服务开屏广告和淘宝购物红包弹窗规则。

{
  id: 1864279031,
  name: 'shockbladenull 的 GKD 订阅',
  version: 3,
  author: 'shockbladenull',
  updateUrl:
    'https://raw.githubusercontent.com/shockbladenull/gkd-subscription/main/gkd.json5',
  checkUpdateUrl: './gkd.version.json5',
  supportUri: 'https://github.com/shockbladenull/gkd-subscription',
  categories: [],
  globalGroups: [],
  apps: [
    {
      id: 'com.miui.systemAdSolution',
      name: '智能服务',
      groups: [
        {
          key: 0,
          name: '开屏广告',
          matchTime: 10000,
          actionMaximum: 1,
          resetMatch: 'app',
          matchRoot: true,
          rules: [
            {
              key: 0,
              matches:
                '[vid="view_skip_button"][text^="跳过广告"][clickable=true][visibleToUser=true]',
            },
          ],
        },
      ],
    },
    {
      id: 'com.taobao.taobao',
      name: '淘宝',
      groups: [
        {
          key: 1,
          name: '关闭购物红包弹窗',
          activityIds: [
            'com.taobao.themis.container.app.TMSActivity',
          ],
          matchRoot: true,
          resetMatch: 'activity',
          actionMaximum: 1,
          rules: [
            {
              key: 0,
              matches: [
                'TextView[text*="购物红包"][visibleToUser=true]',
                'Button[text="关闭"][clickable=true][visibleToUser=true]',
              ],
              action: 'click',
            },
          ],
        },
      ],
    },
  ],
}
